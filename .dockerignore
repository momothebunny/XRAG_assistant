# Top-level .dockerignore — applies to ALL builds whose context is the
# repo root (both backend.Dockerfile and frontend.Dockerfile use that).

# Version control & editor cruft
.git
.gitignore
.gitattributes
.vscode
.idea
*.swp

# Python
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/htmlcov
**/.coverage
**/*.egg-info

# Node / Vite
**/node_modules
**/dist
**/.vite
**/coverage

# Local env / secrets — these MUST stay out of images
**/.env
**/.env.*
!**/.env.example
backend/data/.auth_secret
backend/data/users.json
backend/data/api_keys.json

# OS junk
.DS_Store
Thumbs.db

# Docs/repo metadata not needed at build time
README.md
*.md
docs/
docker-compose.override.yml

# Local data dumps (backend/data is bind-mounted at runtime instead)
backend/data/knowledge/uploads/**
backend/data/audit_sessions.json
backend/data/benchmark_runs.json

# CI / test artifacts
.github
backend/tests
recolor_process.ps1
