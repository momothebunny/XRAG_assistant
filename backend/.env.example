# ─────────────────────────────────────────────────────────────────────────
# Aurelia — backend environment variables
#
# Copy this file to `.env` and fill in real values. The auth module will
# auto-load `.env` from this directory on the first email-send attempt.
# `.env` is git-ignored — do NOT commit your real credentials.
# ─────────────────────────────────────────────────────────────────────────


# ── SMTP (verification emails) ──────────────────────────────────────────
# When XRAG_SMTP_HOST is empty, the verification code is logged to the
# server console and (only if XRAG_AUTH_DEV_MODE=1) returned in the API
# response so you can keep developing without email delivery.

# === Gmail (recommended for personal use) ===============================
# Requires 2FA on the Google account + a 16-char App Password.
# Generate at: https://myaccount.google.com/apppasswords
# XRAG_SMTP_HOST=smtp.gmail.com
# XRAG_SMTP_PORT=587
# XRAG_SMTP_TLS=1
# XRAG_SMTP_USER=you@gmail.com
# XRAG_SMTP_PASSWORD=xxxxxxxxxxxxxxxx
# XRAG_SMTP_FROM=you@gmail.com
# XRAG_SMTP_FROM_NAME=Aurelia

# === Outlook / Microsoft 365 ============================================
# XRAG_SMTP_HOST=smtp.office365.com
# XRAG_SMTP_PORT=587
# XRAG_SMTP_TLS=1
# XRAG_SMTP_USER=you@outlook.com
# XRAG_SMTP_PASSWORD=your-app-password
# XRAG_SMTP_FROM=you@outlook.com
# XRAG_SMTP_FROM_NAME=Aurelia

# === SendGrid ===========================================================
# XRAG_SMTP_HOST=smtp.sendgrid.net
# XRAG_SMTP_PORT=587
# XRAG_SMTP_TLS=1
# XRAG_SMTP_USER=apikey
# XRAG_SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxxxxxx
# XRAG_SMTP_FROM=verified-sender@yourdomain.com
# XRAG_SMTP_FROM_NAME=Aurelia

# === Mailgun ============================================================
# XRAG_SMTP_HOST=smtp.mailgun.org
# XRAG_SMTP_PORT=587
# XRAG_SMTP_TLS=1
# XRAG_SMTP_USER=postmaster@mg.yourdomain.com
# XRAG_SMTP_PASSWORD=your-mailgun-smtp-password
# XRAG_SMTP_FROM=no-reply@yourdomain.com
# XRAG_SMTP_FROM_NAME=Aurelia


# ── Auth dev mode ───────────────────────────────────────────────────────
# When 1, the verification code is included in the registration response
# JSON. NEVER set this in production.
XRAG_AUTH_DEV_MODE=1
