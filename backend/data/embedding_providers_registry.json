{
  "$schema_version": "1.0.0",
  "$description": "Provider-first embedding catalog. Each entry declares credential fields, provider-specific additional params, and model list.",
  "providers": [
    {
      "id": "openai",
      "label": "OpenAI Embedding",
      "badge": "OpenAI",
      "description": "OpenAI API to generate embeddings for a given text.",
      "credentialFields": [
        { "env_var": "OPENAI_API_KEY", "label": "OpenAI API Key", "placeholder": "sk-...", "required": true, "secret": true }
      ],
      "additionalFields": [],
      "models": [
        { "id": "text-embedding-3-large",  "label": "text-embedding-3-large",          "dimensions": 3072, "maxTokens": 8191 },
        { "id": "text-embedding-3-small",  "label": "text-embedding-3-small",          "dimensions": 1536, "maxTokens": 8191 },
        { "id": "text-embedding-ada-002",  "label": "text-embedding-ada-002 (Legacy)", "dimensions": 1536, "maxTokens": 8191 }
      ]
    },
    {
      "id": "openai_custom",
      "label": "OpenAI Custom Embedding",
      "badge": "Custom",
      "description": "OpenAI-compatible API at a custom base URL (proxy / fine-tuned endpoint).",
      "credentialFields": [
        { "env_var": "OPENAI_API_KEY", "label": "OpenAI-compatible API Key", "placeholder": "sk-...", "required": true, "secret": true }
      ],
      "additionalFields": [
        { "key": "openaiBaseUrl", "label": "Custom base URL", "type": "text", "placeholder": "https://my-proxy.example.com/v1", "required": true }
      ],
      "models": []
    },
    {
      "id": "azure_openai",
