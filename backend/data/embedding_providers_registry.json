      ],
      "additionalFields": [
        { "key": "azureEndpoint",   "label": "Azure endpoint",   "type": "text", "placeholder": "https://<name>.openai.azure.com/", "required": true },
        { "key": "azureDeployment", "label": "Deployment name",  "type": "text", "placeholder": "my-embed-deployment",              "required": true },
        { "key": "azureApiVersion", "label": "API version",      "type": "text", "placeholder": "2024-02-01",                       "required": false }
      ],
      "models": [
        { "id": "text-embedding-3-large", "label": "text-embedding-3-large", "dimensions": 3072, "maxTokens": 8191 },
        { "id": "text-embedding-3-small", "label": "text-embedding-3-small", "dimensions": 1536, "maxTokens": 8191 }
